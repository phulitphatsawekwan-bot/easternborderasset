// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model Profile {
  id          Int          @id @default(autoincrement())
  clerkId     String       @unique
  firstname   String
  lastname    String
  email       String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  eastborders Eastborder[]
  favorites   Favorite[]
}

model Eastborder {
  id          Int        @id @default(autoincrement())
  title       String
  description String     @db.VarChar(500)
  lat         Float
  lng         Float
  price       Int
  secure_url  String
  public_id   String
  category    String
  type        String
  space       Float
  bedroom     String
  bathroom    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  profile     Profile    @relation(fields: [profileId], references: [clerkId])
  profileId   String
  favorites   Favorite[]
  // Gallery (up to 10 — the cap is enforced in the app/zod layer).
  // secure_url/public_id above stay as the cover image (images[0]) for
  // backward compatibility with existing reads.
  images      EastborderImage[]
}

model EastborderImage {
  id           Int        @id @default(autoincrement())
  secure_url   String
  public_id    String
  eastborder   Eastborder @relation(fields: [eastborderId], references: [id], onDelete: Cascade)
  eastborderId Int
  createdAt    DateTime   @default(now())
}

model Favorite {
  id           Int         @id @default(autoincrement())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  profile      Profile    @relation(fields: [profileId], references: [clerkId])
  profileId    String
  eastborder   Eastborder @relation(fields: [eastborderId], references: [id])
  eastborderId Int
}
