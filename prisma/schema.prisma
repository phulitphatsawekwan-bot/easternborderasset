// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DIRECT_URL")
}


model Profile {
  id          Int          @id @default(autoincrement())
  clerkId     String       @unique
  firstname   String
  lastname    String
  email       String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  eastborders Eastborder[]
  favorites   Favorite[]
}

model Eastborder {
  id          Int        @id @default(autoincrement())
  title       String
  description String     @db.VarChar(500)
  lat         Float
  lng         Float
  price       Int
  secure_url  String
  public_id   String
  category    String
  type        String
  space       Int
  bedroom     String
  bathroom    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  profile     Profile    @relation(fields: [profileId], references: [clerkId])
  profileId   String
  favorites   Favorite[]
}

model Favorite {
  id           Int         @id @default(autoincrement())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  profile      Profile    @relation(fields: [profileId], references: [clerkId])
  profileId    String
  eastborder   Eastborder @relation(fields: [eastborderId], references: [id])
  eastborderId Int
}
